# QA Prism environment variables.
# Copy to `.env` and fill in. Services fail fast with a clear message if a
# required var is missing (see §3 of the build spec).

# --- Datastores (provided by infra/docker-compose.yml for local dev) ---
DATABASE_URL="postgresql://qaprism:qaprism@localhost:5432/qaprism?schema=public"
REDIS_URL="redis://localhost:6379"

# --- LLM (packages/llm) ---
# Never commit a real key. Read from env only.
ANTHROPIC_API_KEY=""

# --- PR impact analyser (packages/impact-analyser) ---
GITHUB_TOKEN=""

# --- Ticketing (packages/ticketing) — optional; features gate off if unset ---
JIRA_BASE_URL=""
JIRA_TOKEN=""
LINEAR_API_KEY=""
