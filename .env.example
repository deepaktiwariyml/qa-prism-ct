# QA Prism environment variables.
# Copy to `.env` and fill in. Services fail fast with a clear message if a
# required var is missing (see §3 of the build spec).

# --- Datastores (provided by infra/docker-compose.yml for local dev) ---
DATABASE_URL="postgresql://qaprism:qaprism@localhost:5432/qaprism?schema=public"
REDIS_URL="redis://localhost:6379"

# --- Dashboard (apps/web) ---
# Shared password that gates the whole dashboard. Share this with the QA team.
# When unset, no valid login is possible (the app stays locked).
APP_PASSWORD=""
# The Fastify API base, reached only server-side (Server Components + the /api
# BFF proxy). Never exposed to the browser, so the API can be kept private.
API_INTERNAL_URL="http://localhost:3001"
# How long a scan (and its findings/report) is kept before auto-deletion.
SCAN_RETENTION_MINUTES="60"
# Feature flag for the FUN section (word-search game). Only "true" shows it.
FUN_ENABLED="true"
# Company the FUN game is themed/branded around (words + branding).
COMPANY_NAME="Code and Theory"

# --- LLM (packages/llm) ---
# Never commit a real key. Read from env only.
ANTHROPIC_API_KEY=""
# Model for quality-critical calls (impact analysis, test-case generation,
# scripted-login field detection). Balanced cost/quality default.
ANTHROPIC_MODEL="claude-sonnet-4-6"
# Cheaper model for low-stakes calls (FUN word game, test-case column auto-fill).
ANTHROPIC_FAST_MODEL="claude-haiku-4-5"

# --- PR impact analyser (packages/impact-analyser) ---
GITHUB_TOKEN=""

# --- Ticketing — optional ---
# Base URL of your Jira instance, e.g. https://your-org.atlassian.net
# The impact analyser detects ticket keys (ABC-123) in the PR title, body,
# branch name, and commit messages; set this so bare keys become clickable
# links. If the PR already contains a full Jira/Linear URL, links work with
# no config. Also used to gate other optional ticketing features.
JIRA_BASE_URL=""
JIRA_TOKEN=""
LINEAR_API_KEY=""
