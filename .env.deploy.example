# Copy to `.env` on the server (next to docker-compose.yml) and fill in.
# docker compose reads this file automatically for ${VAR} substitution.
# Keep it private:  chmod 600 .env

# Strong random password for Postgres (any long random string).
POSTGRES_PASSWORD=change-me-to-a-long-random-string

# Shared team password for the whole app (share with QA).
APP_PASSWORD=set-a-team-password

# Claude API key (from your org). Enables the impact analyser + FUN word lists.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: GitHub token for private-repo PRs / higher rate limits.
GITHUB_TOKEN=

# Branding + behaviour.
COMPANY_NAME=Code and Theory
SCAN_RETENTION_MINUTES=60
FUN_ENABLED=true

# Public hostname (must have a DNS A record → this VPS's IP). Use the same
# domain your Traefik already serves certs for.
SITE_ADDRESS=qa-prism.dtdkauto.cloud

# --- Existing Traefik integration ---
# Fill these from your running Traefik setup. Discover them with:
#   docker inspect n8n-darshan --format '{{range $k,$v := .Config.Labels}}{{println $k "=" $v}}{{end}}' | grep -i traefik
#   docker inspect n8n-darshan --format '{{range $k,$v := .NetworkSettings.Networks}}{{println $k}}{{end}}'
# TRAEFIK_NETWORK  = the shared proxy network (likely `web`)
# TRAEFIK_ENTRYPOINT = the HTTPS entrypoint name (often `websecure`)
# CERT_RESOLVER    = the ACME cert resolver name from n8n's labels
TRAEFIK_NETWORK=web
TRAEFIK_ENTRYPOINT=websecure
CERT_RESOLVER=
