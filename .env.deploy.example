# Copy to `.env` on the server (next to docker-compose.yml) and fill in.
# docker compose reads this file automatically for ${VAR} substitution.
# Keep it private:  chmod 600 .env

# Strong random password for Postgres (any long random string).
POSTGRES_PASSWORD=change-me-to-a-long-random-string

# Shared team password for the whole app (share with QA).
APP_PASSWORD=set-a-team-password

# Claude API key (from your org). Enables the impact analyser + FUN word lists.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: GitHub token for private-repo PRs / higher rate limits.
GITHUB_TOKEN=

# Branding + behaviour.
COMPANY_NAME=Code and Theory
SCAN_RETENTION_MINUTES=60
FUN_ENABLED=true

# Public address Caddy serves on.
#   domain -> automatic HTTPS (recommended, e.g. qa-prism.duckdns.org)
#   :443   -> self-signed (edit Caddyfile per its note)
SITE_ADDRESS=qa-prism.example.com
