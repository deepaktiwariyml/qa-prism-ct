{
  "id": "restassured-java",
  "supports": {
    "platforms": ["api"],
    "language": "java",
    "framework": "restassured",
    "reporters": ["allure", "extent"]
  },
  "variables": {
    "projectName": { "type": "string", "default": "qa-api-automation" },
    "apiBaseUrl": { "type": "url", "default": "https://reqres.in/api" }
  },
  "dependencyRender": { "format": "maven-xml", "token": "dependencies" },
  "dependencies": {
    "io.rest-assured:rest-assured": "5.5.0",
    "org.testng:testng": "7.10.2",
    "org.hamcrest:hamcrest": "2.2"
  },
  "reporterDependencies": {
    "allure": {
      "io.qameta.allure:allure-testng": "2.29.0",
      "io.qameta.allure:allure-rest-assured": "2.29.0"
    },
    "extent": {
      "com.aventstack:extentreports": "5.1.2",
      "tech.grasshopper:extentreports-testng-adapter": "1.2.4"
    }
  },
  "reporterTokens": {
    "allure": { "testngListener": "<listener class-name=\"io.qameta.allure.testng.AllureTestNg\"/>" },
    "extent": { "testngListener": "<listener class-name=\"com.aventstack.extentreports.testng.listener.ExtentITestListener\"/>" }
  },
  "files": "files",
  "partials": ["ci/github-actions-java.yml.tmpl"],
  "postGenerate": ["python3 -c \"import xml.dom.minidom; xml.dom.minidom.parse('pom.xml'); print('pom.xml is well-formed')\""],
  "notes": "Build/run on your machine with Maven: `mvn test` (JDK 11+ and Maven required)."
}
