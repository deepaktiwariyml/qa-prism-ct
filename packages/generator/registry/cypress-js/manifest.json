{
  "id": "cypress-js",
  "supports": {
    "platforms": [
      "web",
      "web-api"
    ],
    "language": "javascript",
    "framework": "cypress",
    "reporters": [
      "mochawesome",
      "html"
    ]
  },
  "variables": {
    "projectName": {
      "type": "string",
      "default": "qa-automation"
    },
    "webBaseUrl": {
      "type": "url",
      "default": "https://example.cypress.io"
    },
    "apiBaseUrl": {
      "type": "url",
      "default": "https://jsonplaceholder.typicode.com"
    }
  },
  "dependencyRender": {
    "format": "npm-json",
    "token": "dependencies"
  },
  "dependencies": {
    "cypress": "^13.15.0"
  },
  "reporterDependencies": {
    "mochawesome": {
      "mochawesome": "^7.1.3",
      "mochawesome-merge": "^4.3.0",
      "mochawesome-report-generator": "^6.2.0"
    },
    "html": {}
  },
  "reporterTokens": {
    "mochawesome": {
      "reporterConfig": "    reporter: 'mochawesome',\n    reporterOptions: { reportDir: 'cypress/reports', overwrite: false, html: true, json: true },"
    },
    "html": {
      "reporterConfig": ""
    }
  },
  "files": "files",
  "partials": [
    "ci/github-actions.yml.tmpl"
  ],
  "postGenerate": [
    "npm install --no-audit --no-fund",
    "npx cypress verify"
  ]
}