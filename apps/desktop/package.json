{
  "name": "@qa-prism/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "description": "QA Studio desktop app (Electron) — LLM-powered QA tools.",
  "scripts": {
    "build:main": "esbuild src/main.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist/main.js --external:electron --log-level=warning",
    "build:web": "pnpm --filter @qa-prism/web build && node scripts/assemble-web.mjs",
    "build:web:dev": "pnpm --filter @qa-prism/web build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "pnpm run build:main && pnpm run build:web:dev && electron .",
    "start": "electron .",
    "dist:mac": "pnpm run build:main && pnpm run build:web && electron-builder --mac"
  },
  "devDependencies": {
    "@qa-prism/core": "workspace:*",
    "@qa-prism/generator": "workspace:*",
    "@qa-prism/impact-analyser": "workspace:*",
    "@qa-prism/llm": "workspace:*",
    "@types/node": "^22.7.4",
    "cross-env": "^7.0.3",
    "electron": "^33.0.2",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.2",
    "zod": "^3.23.8"
  },
  "build": {
    "appId": "com.codeandtheory.qastudio",
    "productName": "QA Studio",
    "directories": { "output": "release" },
    "files": ["dist/**/*", "preload.cjs", "main-preload.cjs", "settings.html", "package.json"],
    "extraResources": [
      { "from": "build-web", "to": "web" },
      { "from": "../../packages/generator/registry", "to": "generator/registry" },
      { "from": "../../packages/generator/partials", "to": "generator/partials" }
    ],
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.developer-tools",
      "artifactName": "QA-Studio-${version}-${arch}.${ext}"
    },
    "dmg": { "title": "QA Studio ${version}" }
  }
}
