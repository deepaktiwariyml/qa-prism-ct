{
  "name": "@qa-prism/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "dotenv -e ../../.env -- tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@qa-prism/breakage-analyser": "workspace:*",
    "@qa-prism/core": "workspace:*",
    "@qa-prism/db": "workspace:*",
    "@qa-prism/generator": "workspace:*",
    "@qa-prism/impact-analyser": "workspace:*",
    "@qa-prism/llm": "workspace:*",
    "@qa-prism/scanner-accessibility": "workspace:*",
    "@qa-prism/scanner-automation": "workspace:*",
    "@qa-prism/scanner-performance": "workspace:*",
    "@qa-prism/scanner-security": "workspace:*",
    "@qa-prism/scoring": "workspace:*",
    "bullmq": "^5.28.0",
    "fastify": "^5.1.0",
    "ioredis": "^5.4.1",
    "playwright": "^1.48.0",
    "sharp": "^0.35.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.4",
    "tsx": "^4.19.2",
    "vitest": "^2.1.5"
  }
}
