{
  "name": "qa-prism",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "QA Prism — unified quality-intelligence platform for QA engineers.",
  "packageManager": "pnpm@10.18.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "db:migrate": "dotenv -e .env -- pnpm --filter @qa-prism/db exec prisma migrate deploy",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@types/node": "^22.9.0",
    "dotenv-cli": "^7.4.4",
    "eslint": "^9.14.0",
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.14.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "prisma",
      "@prisma/client",
      "@prisma/engines"
    ],
    "overrides": {
      "ioredis": "5.11.1"
    }
  }
}
